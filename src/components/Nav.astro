---
import Mark from './Mark.astro';
---
<header class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="brand" aria-label="Nuthatch home">
      <Mark size={26} />
      <span>nuthatch</span>
    </a>
    <nav class="nav-links" aria-label="Primary">
      <a href="/install">Install</a>
      <a href="/example">Example</a>
      <a href="/stories">Stories</a>
      <a href="/roadmap">Roadmap</a>
      <a href="/manifesto">Manifesto</a>
      <a href="https://github.com/nuthatch-indexer/nuthatch" rel="noopener">GitHub</a>
      <!-- CSS-only theme toggle: a :has() checkbox hack, zero JavaScript. -->
      <input type="checkbox" id="theme-toggle" class="theme-input" aria-label="Switch to light theme" />
      <label for="theme-toggle" class="theme-toggle" title="Toggle light / dark">
        <span class="theme-dot" aria-hidden="true"></span>
        <span class="theme-word theme-word--dark">dark</span>
        <span class="theme-word theme-word--light">light</span>
      </label>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 58px;
  }
  .brand {
    display: inline-flex; align-items: center; gap: 0.5rem;
    color: var(--text); font-weight: 600; letter-spacing: -0.02em; font-size: 1.02rem;
  }
  .brand:hover { text-decoration: none; }
  .nav-links { display: flex; align-items: center; gap: clamp(0.9rem, 2.4vw, 1.6rem); }
  .nav-links a { color: var(--text-muted); font-size: 0.92rem; }
  .nav-links a:hover { color: var(--text); text-decoration: none; }

  .theme-input { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }
  .theme-toggle {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: 'JetBrains Mono', monospace; font-size: 0.72rem;
    color: var(--text-muted); cursor: pointer; user-select: none;
    border: 1px solid var(--border); border-radius: 9999px;
    padding: 0.22rem 0.6rem 0.22rem 0.5rem;
    transition: border-color 0.18s var(--ease), color 0.18s var(--ease);
  }
  .theme-toggle:hover { color: var(--text); border-color: var(--border-hi); }
  .theme-input:focus-visible + .theme-toggle { outline: 2px solid var(--accent); outline-offset: 2px; }
  .theme-dot {
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--rust); box-shadow: inset 0 0 0 3px var(--bg);
    transition: background 0.2s var(--ease);
  }
  :root:has(#theme-toggle:checked) .theme-dot { background: var(--warn); }
  .theme-word--light { display: none; }
  :root:has(#theme-toggle:checked) .theme-word--dark { display: none; }
  :root:has(#theme-toggle:checked) .theme-word--light { display: inline; }

  @media (max-width: 30rem) {
    .theme-word { display: none !important; }
  }
</style>
