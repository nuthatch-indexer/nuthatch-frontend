---
import Mark from './Mark.astro';
---
<header class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="brand" aria-label="Nuthatch home">
      <Mark size={26} />
      <span>nuthatch</span>
    </a>

    <!-- CSS-only menu toggle: a :has() checkbox hack, zero JavaScript (matches the theme toggle). -->
    <input type="checkbox" id="nav-toggle" class="nav-input" aria-label="Toggle menu" />
    <label for="nav-toggle" class="nav-burger" title="Menu">
      <span></span><span></span><span></span>
    </label>

    <nav class="nav-links" aria-label="Primary">
      <a href="/install">Install</a>
      <a href="/docs">Docs</a>
      <a href="/example">Example</a>
      <a href="/nests">Nests</a>
      <a href="/stories">Stories</a>
      <a href="/blog">Blog</a>
      <a href="/roadmap">Roadmap</a>
      <a href="/manifesto">Manifesto</a>
      <a href="https://github.com/nuthatch-indexer/nuthatch" rel="noopener">GitHub</a>
      <!-- CSS-only theme toggle: a :has() checkbox hack, zero JavaScript. -->
      <input type="checkbox" id="theme-toggle" class="theme-input" aria-label="Switch to light theme" />
      <label for="theme-toggle" class="theme-toggle" title="Toggle light / dark">
        <span class="theme-dot" aria-hidden="true"></span>
        <span class="theme-word theme-word--dark">dark</span>
        <span class="theme-word theme-word--light">light</span>
      </label>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    position: relative;
    display: flex; align-items: center; justify-content: space-between;
    height: 58px;
  }
  .brand {
    display: inline-flex; align-items: center; gap: 0.5rem;
    color: var(--text); font-weight: 600; letter-spacing: -0.02em; font-size: 1.02rem;
  }
  .brand:hover { text-decoration: none; }
  .nav-links { display: flex; align-items: center; gap: clamp(0.9rem, 2.4vw, 1.6rem); }
  .nav-links a { color: var(--text-muted); font-size: 0.92rem; }
  .nav-links a:hover { color: var(--text); text-decoration: none; }

  /* Hamburger — hidden on desktop, a CSS-only toggle on mobile. */
  .nav-input { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }
  .nav-burger {
    display: none; flex-direction: column; gap: 4px; cursor: pointer;
    padding: 9px 8px; margin: -9px -8px; border-radius: 8px;
  }
  .nav-burger span {
    display: block; width: 20px; height: 2px; border-radius: 2px;
    background: var(--text-muted); transition: transform 0.2s var(--ease), opacity 0.2s var(--ease);
  }
  .nav-burger:hover span { background: var(--text); }
  .nav-input:focus-visible + .nav-burger { outline: 2px solid var(--accent); outline-offset: 3px; }

  .theme-input { position: absolute; opacity: 0; pointer-events: none; width: 0; height: 0; }
  .theme-toggle {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: 'JetBrains Mono', monospace; font-size: 0.72rem;
    color: var(--text-muted); cursor: pointer; user-select: none;
    border: 1px solid var(--border); border-radius: 9999px;
    padding: 0.22rem 0.6rem 0.22rem 0.5rem;
    transition: border-color 0.18s var(--ease), color 0.18s var(--ease);
  }
  .theme-toggle:hover { color: var(--text); border-color: var(--border-hi); }
  .theme-input:focus-visible + .theme-toggle { outline: 2px solid var(--accent); outline-offset: 2px; }
  .theme-dot {
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--rust); box-shadow: inset 0 0 0 3px var(--bg);
    transition: background 0.2s var(--ease);
  }
  :root[data-theme='light'] .theme-dot { background: var(--warn); }
  .theme-word--light { display: none; }
  :root[data-theme='light'] .theme-word--dark { display: none; }
  :root[data-theme='light'] .theme-word--light { display: inline; }

  /* Mobile: collapse the links into a dropdown behind the hamburger. */
  @media (max-width: 48rem) {
    .nav-burger { display: inline-flex; }
    .nav-links {
      display: none;
      position: absolute; top: 58px; left: 0; right: 0;
      flex-direction: column; align-items: stretch; gap: 0;
      background: var(--bg-elev); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 0.4rem;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
    }
    :root:has(#nav-toggle:checked) .nav-links { display: flex; }
    .nav-links a { padding: 0.7rem 0.8rem; border-radius: var(--radius-sm); font-size: 0.98rem; }
    .nav-links a:hover { background: var(--bg-inset); }
    .theme-toggle { align-self: flex-start; margin: 0.4rem 0.8rem 0.2rem; }
    /* Burger → X when open. */
    :root:has(#nav-toggle:checked) .nav-burger span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    :root:has(#nav-toggle:checked) .nav-burger span:nth-child(2) { opacity: 0; }
    :root:has(#nav-toggle:checked) .nav-burger span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
  }
</style>
