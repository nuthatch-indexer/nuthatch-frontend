---
// The nuthatch mark: a rounded badge - a cream nuthatch on a dark tile with an
// amber eye. Fixed brand colours; the tile keeps the cream mark legible on both
// the light and dark themes. Inline SVG, so it costs no extra request.
interface Props { size?: number; class?: string }
const { size = 28, class: cls = '' } = Astro.props;
---
<svg
  class={cls}
  width={size}
  height={size}
  viewBox="0 0 512 512"
  role="img"
  aria-label="Nuthatch"
  style="display:block;"
>
  <rect width="512" height="512" rx="96" fill="#171614" />
  <path d="M104,112 H180 V400 H104 Z" fill="#EDE6DA" />
  <path d="M332,112 H408 V400 H332 Z" fill="#EDE6DA" />
  <path d="M104,86 L180,124 L318,318 L318,404 L312,452 L286,408 L104,204 Z" fill="#EDE6DA" />
  <circle cx="296" cy="374" r="14" fill="#D97706" />
</svg>
